MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1949365663}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3bebecf57c17a6047b235819d365d1f3, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DisplayGuidance
  Guides:
  - index: 0
    text: 'Wake up, Captain. We need you at the control booth. '
    cooldown: 4
  - index: 1
    text: Not too hard to move right? Well wait till we get going.
    cooldown: 4
  - index: 2
    text: Engaging thursters in 3... 2... 1...
    cooldown: 4
  - index: 3
    text: Not so easy now, right?
    cooldown: 4
  - index: 4
    text: Don't worry about hitting the wall hard. What's important is that your
      G-force is now up-to-speed with the ship. Now get over here.
    cooldown: 8
  - index: 5
    text: Here let me help you out.
